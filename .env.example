# Device (optional — auto-detects first listed iOS device if omitted)
UDID=your-device-udid

# App
APP_BUNDLE_ID=com.example.YourApp

# Log parsing (required)
LOG_DATE_REGEX=^\[(\d{2}/[A-Za-z]{3}/\d{4}:\d{2}:\d{2}:\d{2})\]
LOG_DATE_FORMAT=%d/%b/%Y:%H:%M:%S
LOG_EXTRACT_REGEX=your-extract-pattern
LOG_EXTRACT_EXCLUDE=value-to-exclude

# Report form variables (optional)
# These populate optional values in the generated JSON report.
FORM_VAR_1=   # maps to "variable_name_1"
FORM_VAR_3=   # maps to "variable_name_3"
FORM_VAR_4=   # maps to "variable_name_4"
FORM_VAR_5=   # maps to "variable_name_5"
FORM_VAR_6=   # maps to "variable_name_6"
